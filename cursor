// --- Utility Functions ---

export class RequestHandler {
  public handle(routeId: string): void {
    const route = systemRoutes.find(r => r.id === routeId);
    if (!route) {
      throw new Error(`Route ${routeId} not found.`);
    }
    if (route.deprecated) {
      console.warn(`Warning: Route ${routeId} is deprecated.`);
    }
    console.log(`Handling ${route.method} request for ${route.path}`);
  }
}

export function validateAllRoutes(): boolean {
  let isValid = true;
  const ids = new Set<string>();
  const paths = new Set<string>();

  for (const route of systemRoutes) {
    if (ids.has(route.id)) {
      console.error(`Duplicate route ID found: ${route.id}`);
      isValid = false;
    }
    ids.add(route.id);

    const pathKey = `${route.method}:${route.path}`;
    if (paths.has(pathKey)) {
      console.error(`Duplicate route path/method combination found: ${pathKey}`);
      isValid = false;
    }
    paths.add(pathKey);
  }

  return isValid;
}

export function getActiveRoutes(): RouteConfig[] {
  return systemRoutes.filter(route => !route.deprecated);
}

export function getRoutesByMethod(method: HttpMethod): RouteConfig[] {
  return systemRoutes.filter(route => route.method === method);
}

export function findRouteByPath(path: string, method: HttpMethod): RouteConfig | undefined {
  return systemRoutes.find(route => route.path === path && route.method === method);
}

export class CacheManager {
  private cache = new Map<string, any>();

  public get(key: string): any {
    return this.cache.get(key);
  }

  public set(key: string, value: any, ttl: number): void {
    this.cache.set(key, value);
    if (ttl > 0) {
      setTimeout(() => {
        this.cache.delete(key);
      }, ttl * 1000);
    }
  }

  public clear(): void {
    this.cache.clear();
  }
}

export const cacheManager = new CacheManager();

// --- Initialization ---

export function initializeSystem(): void {
  console.log('Initializing system routing table...');
  if (!validateAllRoutes()) {
    console.error('System initialization failed due to invalid routes.');
    process.exit(1);
  }
  
  const activeCount = getActiveRoutes().length;
  console.log(`System initialized successfully with ${activeCount} active routes.`);
}

